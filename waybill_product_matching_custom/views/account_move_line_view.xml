<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_move_form_inherited" model="ir.ui.view">
        <field name="name">view.move.form.inherited</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='invoice_line_ids']//field[@name='price_subtotal']" position="attributes">
                <attribute name="string">Subtotal</attribute>
            </xpath>
            <xpath expr="//field[@name='invoice_line_ids']//field[@name='price_subtotal']" position="after">
                <field name="price_total"/>
            </xpath>
        </field>
    </record>
</odoo>
