<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Wizard view -->
    <record id="view_sawyisi_nashti_wizard_form" model="ir.ui.view">
        <field name="name">sawyisi.nashti.wizard.form</field>
        <field name="model">sawyisi.nashti.wizard</field>
        <field name="arch" type="xml">
            <form string="საწყისი ნაშთი Excel">
                <group>
                    <group>
                        <field name="file_data" filename="file_name"/>
                        <field name="file_name" invisible="1"/>
                        <field name="journal_id"/>
                        <field name="date"/>
                    </group>
                    <group>
                        <field name="start_row"/>
                        <field name="end_row"/>
                    </group>
                </group>
                <footer>
                    <button string="Import" type="object" name="action_import_excel" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Window action for wizard -->
    <record id="action_sawyisi_nashti_wizard" model="ir.actions.act_window">
        <field name="name">საწყისი ნაშთი</field>
        <field name="res_model">sawyisi.nashti.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_sawyisi_nashti_wizard_form"/>
        <field name="target">new</field>
    </record>

    <!-- Inherit account.move tree view to add header button -->
    <record id="view_move_tree_inherit_sawyisi_nashti" model="ir.ui.view">
        <field name="name">account.move.tree.inherit.sawyisi_nashti</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//list" position="inside">
                <header>
                    <button type="action"
                            name="%(action_sawyisi_nashti_wizard)d"
                            string="საწყისი ნაშთი"
                            class="btn-secondary"
                            display="always"/>
                </header>
            </xpath>
        </field>
    </record>

</odoo>

