<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="ir_cron_update_stock_quant_free_quantity" model="ir.cron">
        <field name="name">Update Stock Quant Free Quantity</field>
        <field name="model_id" ref="stock.model_stock_quant"/>
        <field name="state">code</field>
        <field name="code">model.cron_update_free_quantity()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active">True</field>
        <field name="nextcall" eval="DateTime.now().strftime('%Y-%m-%d 00:00:00')"/>
    </record>
</odoo>
