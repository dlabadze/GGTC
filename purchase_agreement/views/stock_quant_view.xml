<odoo>
    <!-- Inherit stock.quant tree view to add free_quantity column -->
    <record id="view_stock_quant_tree_free_quantity" model="ir.ui.view">
        <field name="name">stock.quant.tree.free.quantity</field>
        <field name="model">stock.quant</field>
        <field name="inherit_id" ref="stock.view_stock_quant_tree_editable"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='reserved_quantity']" position="after">
                <field name="free_quantity"/>
            </xpath>
        </field>
    </record>
</odoo>


