<odoo>
<record id="view_move_line_tree_inherit_request" model="ir.ui.view">
    <field name="name">stock.move.line.tree.inherit</field>
    <field name="model">stock.move.line</field>
    <field name="inherit_id" ref="stock.view_move_line_tree"/>
    <field name="arch" type="xml">
        <xpath expr="//field[@name='reference']" position="after">
            <field name="x_studio_request_number"  string="მოთხოვნის ნომერი" optional="show"/>
            <field name="request_date" string="მოთხოვნის თარიღი" optional="show"/>
            <field name="request_manual_num" string="მოთხოვნის ნომერი (ხელით)" optional="show"/>
        </xpath>
    </field>
</record>
</odoo>