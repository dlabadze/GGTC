<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_inherit_extend_nashti" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.extend.nashti</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="stock.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//app[@name='stock']" position="inside">
                <block title="Stock Control (Remainder)" name="nashti_control_block">
                    <setting id="nashti_control_setting" string="ნაშთის კონტროლი" help="Enable free quantity check for internal moves">
                        <field name="nashti_control"/>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>
