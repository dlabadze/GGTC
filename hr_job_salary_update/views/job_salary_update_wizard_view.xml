<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_job_salary_update_wizard_form" model="ir.ui.view">
        <field name="name">job.salary.update.wizard.form</field>
        <field name="model">job.salary.update.wizard</field>
        <field name="arch" type="xml">
            <form string="Update Expected Salary">
                <group>
                    <field name="operation"/>
                    <field name="percentage"/>
                </group>

                <group>
                    <field name="apply_all"/>
                    <field name="job_ids"
                           widget="many2many_tags"
                           invisible="apply_all"/>
                    <field name="effective_date"/>
                </group>

                <group>
                    <field name="comment"/>
                </group>

                <footer>
                    <button string="დადასტურება"
                            type="object"
                            name="action_apply"
                            class="btn-primary"/>
                    <button string="გაუქმება"
                            special="cancel"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
