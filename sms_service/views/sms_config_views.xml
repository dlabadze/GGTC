<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- SMS Configuration Form View -->
        <record id="view_sms_config_form" model="ir.ui.view">
            <field name="name">sms.config.form</field>
            <field name="model">sms.config</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="test_connection" string="Test Connection" type="object" class="btn-primary"/>
                    </header>
                    <sheet>
                        <group>
                            <group string="Basic Information">
                                <field name="name"/>
                                <field name="active"/>
                            </group>
                            <group string="Service Configuration">
                                <field name="service_url"/>
                                <field name="username"/>
                                <field name="password" password="True"/>
                            </group>
                        </group>
                        <group string="Service Parameters">
                            <group>
                                <field name="client_id"/>
                                <field name="service_id"/>
                            </group>
                            <group>
                                <field name="userid"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- SMS Configuration List View -->
        <record id="view_sms_config_tree" model="ir.ui.view">
            <field name="name">sms.config.tree</field>
            <field name="model">sms.config</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="service_url"/>
                    <field name="username"/>
                    <field name="client_id"/>
                    <field name="service_id"/>
                    <field name="active"/>
                </list>
            </field>
        </record>

        <!-- SMS Configuration Search View -->
        <record id="view_sms_config_search" model="ir.ui.view">
            <field name="name">sms.config.search</field>
            <field name="model">sms.config</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="service_url"/>
                    <field name="username"/>
                    <filter string="Active" name="active" domain="[('active', '=', True)]"/>
                    <filter string="Inactive" name="inactive" domain="[('active', '=', False)]"/>
                </search>
            </field>
        </record>

        <!-- SMS Configuration Action -->
        <record id="action_sms_config" model="ir.actions.act_window">
            <field name="name">SMS Configurations</field>
            <field name="res_model">sms.config</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first SMS configuration!
                </p>
                <p>
                    Configure your SMS service settings including authentication credentials and service parameters.
                </p>
            </field>
        </record>
    </data>
</odoo> 