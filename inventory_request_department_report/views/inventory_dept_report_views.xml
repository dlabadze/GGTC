<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_inventory_dept_report_line_tree" model="ir.ui.view">
        <field name="name">inventory.dept.report.line.tree</field>
        <field name="model">inventory.dept.report.line</field>
        <field name="arch" type="xml">
            <list string="Department Request Report Lines" decoration-danger="is_red">
                <field name="request_ids" widget="many2many_tags"/>
                <field name="product_id"/>
                <field name="september_quantity"/>
                <field name="september_amount"/>
                <field name="quantity"/>
                <field name="amount"/>
                <field name="difference"/>
                <field name="difference_amount"/>
                <field name="is_red" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="action_inventory_dept_report_line" model="ir.actions.act_window">
        <field name="name">Department Request Report Lines</field>
        <field name="res_model">inventory.dept.report.line</field>
        <field name="view_mode">list</field>
    </record>
</odoo>
