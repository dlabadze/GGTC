<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_purchase_requisition_form_inherit_avansi_done_factura" model="ir.ui.view">
        <field name="name">purchase.requisition.form.inherit.avansi.done.factura</field>
        <field name="model">purchase.requisition</field>
        <field name="inherit_id" ref="purchase_requisition.view_purchase_requisition_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_create_done_factura_from_avansi" type="object" string="ფაქტურის შექმნა" class="btn-secondary"/>
                <button name="action_create_done_factura_from_other" type="object" string="სხვა" class="btn-secondary" invisible="not has_other_payment_condition"/>
            </xpath>
            <xpath expr="//sheet/group/group[2]" position="inside">
                <field name="payment_condition_ids" nolabel="1">
                    <list editable="bottom">
                        <field name="payment_condition"/>
                        <field name="days"/>
                    </list>
                </field>
                <field name="has_other_payment_condition" invisible="1"/>
                <field name="other_transfer_date" invisible="not has_other_payment_condition"/>
                <field name="related_account_move_ids" nolabel="1" colspan="2" readonly="1">
                    <list create="false" delete="false" edit="false">
                        <field name="name"/>
                        <field name="payment_state" widget="badge"
                            decoration-success="payment_state == 'paid'"
                            decoration-warning="payment_state in ('partial', 'in_payment')"
                            decoration-danger="payment_state == 'not_paid'"
                            decoration-muted="payment_state in ('reversed', 'blocked', 'invoicing_legacy')"/>
                    </list>
                </field>
            </xpath>
            <xpath expr="//sheet/notebook" position="inside">
                <page string="ავანსები">
                    <field name="avansi_ids">
                        <list editable="bottom">
                            <field name="amount"/>
                            <field name="percentage"/>
                            <field name="date"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
