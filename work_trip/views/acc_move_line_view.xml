<odoo>
    <data>
        <record id="view_move_form_inherit_project" model="ir.ui.view">
            <field name="name">account.move.form.inherit.project</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>

            <field name="arch" type="xml">

                <xpath expr="//field[@name='invoice_line_ids']/list/field[@name='quantity']" position="before">
                    <field name="project_id"/>
                </xpath>

                <xpath expr="//field[@name='line_ids']/list/field[@name='name']" position="after">
                    <field name="project_id"/>
                </xpath>

            </field>
        </record>

    </data>
</odoo>
