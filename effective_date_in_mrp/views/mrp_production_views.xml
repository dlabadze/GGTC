<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_mrp_production_form_effective_date_in_mrp" model="ir.ui.view">
        <field name="name">mrp.production.form.effective.date.in.mrp</field>
        <field name="model">mrp.production</field>
        <field name="inherit_id" ref="mrp.mrp_production_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='group_extra_info']" position="inside">
                <field name="effective_date_in_mrp" required="1" readonly="state == 'done'"/>
            </xpath>
        </field>
    </record>
</odoo>

