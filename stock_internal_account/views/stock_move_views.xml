<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_stock_move_operations_internal_account" model="ir.ui.view">
        <field name="name">stock.move.operations.internal.account</field>
        <field name="model">stock.move</field>
        <field name="inherit_id" ref="stock.view_stock_move_operations"/>
        <field name="arch" type="xml">
            <!-- Add move_account_ang field in the first group after product_id -->
            <!-- Simplified: always visible and editable, no extra conditions -->
            <xpath expr="//group/group[1]//field[@name='product_id']" position="after">
                <field name="move_account_ang"
                       string="Reconciliation Account"
                       options="{'no_create': True}"/>
            </xpath>
        </field>
    </record>
</odoo>
