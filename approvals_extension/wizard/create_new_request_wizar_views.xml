<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Create New Request Wizard Form View -->
    <record id="create_new_request_wizard_form_view" model="ir.ui.view">
        <field name="name">create.new.request.wizard.form</field>
        <field name="model">create.new.request.wizard</field>
        <field name="arch" type="xml">
            <form string="Create New Request">
                <group>
                    <field name="category_id" required="1"/>
                </group>
                <footer>
                    <button string="Create Request" name="create_approval_request" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Wizard Window Action -->
    <record id="action_create_new_request_wizard" model="ir.actions.act_window">
        <field name="name">Create New Request</field>
        <field name="res_model">create.new.request.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>

