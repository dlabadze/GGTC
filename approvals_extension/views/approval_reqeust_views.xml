<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_approval_request_form" model="ir.ui.view">
        <field name="name">approval.request.form</field>
        <field name="model">approval.request</field>
        <field name="inherit_id" ref="approvals.approval_request_view_form"/>
        <field name="arch" type="xml">
           <xpath expr="//header" position="inside">
                <button name="action_create_new_request" string="Create New Request" type="object" 
                class="oe_highlight" icon="fa-plus" invisible="request_status != 'approved'"/>
                <button name="action_sign_documents_2" string="ხელმოწერა" type="object" 
                class="oe_highlight" icon="fa-pencil" invisible="request_status != 'pending' or x_studio_adresati != uid"/>
           </xpath>
           <xpath expr="//notebook" position="inside">
                <page name="related_requests" string="Related Requests">
                    <group>
                        <field name="request_from" widget="many2one_avatar" options="{'no_create': True}" invisible="1"/>
                    </group>            
                    <field name="related_request_ids" readonly="1">
                        <list>
                            <field name="name"/>
                            <button name="action_view_related_request" type="object" string="View" icon="fa-eye"/>
                        </list>
                    </field>
                </page>
           </xpath>
           <xpath expr="//sheet/div[@name='button_box']" position="inside">
                <button name="action_open_related_document" class="oe_stat_button" type="object" invisible="request_from == False">
                    <div class="o_stat_info">
                        <span class="o_stat_value">
                            <field name="request_from" readonly="1"/>
                        </span>
                    </div>
                </button>
                <button name="action_open_root_request" class="oe_stat_button" type="object" invisible="not root_request_id">
                    <div class="o_stat_info">
                        <span class="o_stat_text">Parent Approval</span>
                        <span class="o_stat_value">
                            <field name="root_request_id" readonly="1"/>
                        </span>
                    </div>
                </button>
           </xpath>
        </field>
    </record>
</odoo>