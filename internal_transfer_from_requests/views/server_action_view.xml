<odoo>
    <record id="server_action_generate_internal_transfers" model="ir.actions.server">
        <field name="name">Generate Internal Transfers</field>
        <field name="model_id" ref="inventory_requests.model_inventory_request"/>
        <field name="binding_model_id" ref="inventory_requests.model_inventory_request"/>
        <field name="binding_type">action</field>
        <field name="state">code</field>
        <field name="code">
for record in records:
    record.action_generate_internal_transfers()
        </field>
    </record>

    <record id="server_action_delete_internal_transfers" model="ir.actions.server">
        <field name="name">Delete Internal Transfers</field>
        <field name="model_id" ref="inventory_requests.model_inventory_request"/>
        <field name="binding_model_id" ref="inventory_requests.model_inventory_request"/>
        <field name="binding_type">action</field>
        <field name="state">code</field>
        <field name="code">
action = records.action_delete_internal_transfers()
        </field>
    </record>
</odoo>
