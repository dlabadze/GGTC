<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- URL action for accounting dashboard -->
        <record id="action_accounting_dashboard" model="ir.actions.act_url">
            <field name="name">EGT Sales Dashboard</field>
            <field name="url">/accounting/dashboard</field>
            <field name="target">self</field>
        </record>
        
        <!-- Menu under Accounting -->
        <menuitem 
            id="menu_accounting_dashboard"
            name="📊 EGT Sales Dashboard"
            parent="account.menu_finance"
            action="action_accounting_dashboard"
            sequence="5"/>
            
        <!-- Alternative: Top level menu -->
        <menuitem 
            id="menu_dashboard_main"
            name="📊 Sales Dashboard"
            action="action_accounting_dashboard"
            sequence="5"/>
    </data>
</odoo>