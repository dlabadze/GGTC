<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- =========================================================
         Library list view
         ========================================================= -->
    <record id="view_accounting_library_list" model="ir.ui.view">
        <field name="name">accounting.library.list</field>
        <field name="model">accounting.library</field>
        <field name="arch" type="xml">
            <list string="რეესტრი"
                  decoration-success="state == 'done'"
                  decoration-warning="state == 'awaiting_invoice'"
                  decoration-info="state == 'incoming'">
                <field name="date"/>
                <field name="document_number"/>
                <field name="comment"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'done'"
                       decoration-warning="state == 'awaiting_invoice'"
                       decoration-info="state == 'incoming'"/>
            </list>
        </field>
    </record>

    <!-- =========================================================
         Library form view
         ========================================================= -->
    <record id="view_accounting_library_form" model="ir.ui.view">
        <field name="name">accounting.library.form</field>
        <field name="model">accounting.library</field>
        <field name="arch" type="xml">
            <form string="ჩანაწერი">
                <header>
                    <button name="action_create_vendor_bill"
                            type="object"
                            string="vendor bill ის შექმნა"
                            class="oe_highlight"
                            invisible="vendor_bill_id"/>
                    <button name="action_open_vendor_bill"
                            type="object"
                            string="vendor bill ის ნახვა"
                            invisible="not vendor_bill_id"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="incoming,awaiting_invoice,done"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="date"/>
                            <field name="document_number" readonly="1"/>
                            <field name="partner_id"/>
                            <field name="vendor_bill_id" readonly="1"
                                   invisible="not vendor_bill_id"/>
                            <field name="is_vat_payer"
                                   invisible="not vendor_bill_id"/>
                            <field name="invoice_received"
                                   invisible="not is_vat_payer"/>
                        </group>
                        <group>
                            <field name="inspektireba_id"/>
                            <field name="moxsenebiti_id"/>
                            <field name="approval_id"/>
                        </group>
                    </group>
                    <group string="საფუძველი">
                        <field name="comment" nolabel="1"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- =========================================================
         Library kanban view
         ========================================================= -->
    <record id="view_accounting_library_kanban" model="ir.ui.view">
        <field name="name">accounting.library.kanban</field>
        <field name="model">accounting.library</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state"
                    class="o_kanban_small_column"
                    records_draggable="0">
                <field name="id"/>
                <field name="state"/>
                <field name="document_number"/>
                <field name="partner_id"/>
                <field name="comment"/>
                <field name="date"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_card oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="document_number"/>
                                    </strong>
                                </div>
                            </div>
                            <div class="o_kanban_record_body">
                                <field name="partner_id"/>
                                <div t-if="record.comment.raw_value" class="text-muted">
                                    <field name="comment"/>
                                </div>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_left">
                                    <field name="date"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- =========================================================
         Library search view
         ========================================================= -->
    <record id="view_accounting_library_search" model="ir.ui.view">
        <field name="name">accounting.library.search</field>
        <field name="model">accounting.library</field>
        <field name="arch" type="xml">
            <search string="ძიება">
                <field name="document_number"/>
                <field name="partner_id"/>
                <field name="comment"/>
                <field name="inspektireba_id"/>
                <field name="moxsenebiti_id"/>
                <field name="approval_id"/>
                <filter name="filter_incoming" string="შემოსული"
                        domain="[('state', '=', 'incoming')]"/>
                <filter name="filter_awaiting_invoice" string="ფაქტურის მოლოდინში"
                        domain="[('state', '=', 'awaiting_invoice')]"/>
                <filter name="filter_done" string="დასრულებული"
                        domain="[('state', '=', 'done')]"/>
                <separator/>
                <filter name="filter_vat_payer" string="დღგ-ს გადამხდელი"
                        domain="[('is_vat_payer', '=', True)]"/>
                <filter name="filter_invoice_received" string="ფაქტურა მიღებულია"
                        domain="[('invoice_received', '=', True)]"/>
                <group expand="0" string="დაჯგუფება">
                    <filter name="group_state" string="სტატუსი"
                            context="{'group_by': 'state'}"/>
                    <filter name="group_partner" string="კონტრაგენტი"
                            context="{'group_by': 'partner_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- =========================================================
         Library actions (All / Not Done / Done)
         ========================================================= -->
    <record id="action_accounting_library_all" model="ir.actions.act_window">
        <field name="name">ყველა</field>
        <field name="res_model">accounting.library</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="search_view_id" ref="view_accounting_library_search"/>
    </record>

    <record id="action_accounting_library_not_done" model="ir.actions.act_window">
        <field name="name">დასასრულებელი</field>
        <field name="res_model">accounting.library</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="search_view_id" ref="view_accounting_library_search"/>
        <field name="domain">[('state', 'in', ('incoming', 'awaiting_invoice'))]</field>
        <field name="context">{'default_state': 'incoming'}</field>
    </record>

    <record id="action_accounting_library_done" model="ir.actions.act_window">
        <field name="name">დასრულებული</field>
        <field name="res_model">accounting.library</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="search_view_id" ref="view_accounting_library_search"/>
        <field name="domain">[('state', '=', 'done')]</field>
    </record>

    <!-- =========================================================
         Refresh: pull signed moxsenebiti (for_accounting=True) into the registry
         ========================================================= -->
    <record id="action_accounting_library_refresh" model="ir.actions.server">
        <field name="name">განახლება</field>
        <field name="model_id" ref="model_accounting_library"/>
        <field name="state">code</field>
        <field name="code">action = model.action_refresh_from_moxsenebiti()</field>
    </record>

</odoo>
