<odoo>
    <data>
        <record id="view_picking_form_inherit_fix_date" model="ir.ui.view">
            <field name="name">stock.picking.form.inherit.fix.date</field>
            <field name="model">stock.picking</field>
            <field name="inherit_id" ref="stock.view_picking_form"/>
            <field name="arch" type="xml">
                <xpath expr="//header" position="inside">
                    <button name="action_fix_accounting_dates" 
                            string="Fix Accounting Date" 
                            type="object" 
                            class="btn-secondary" 
                            groups="account.group_account_invoice"
                            invisible="state != 'done'"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
