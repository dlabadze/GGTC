<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- List View -->
    <record id="view_fuel_trip_list" model="ir.ui.view">
        <field name="name">fuel.trip.list</field>
        <field name="model">fuel.trip</field>
        <field name="arch" type="xml">
            <list string="Fuel Trips" create="0" delete="0" editable="bottom">
                <field name="date" readonly="1" width="100px"/>
                <field name="approval_id" readonly="1" options="{'no_create': True}" width="150px"/>
                <field name="trip_type" readonly="1" width="120px"/>
                <field name="trip_purpose" readonly="1" widget="text"/>
                <field name="vehicle_id" readonly="1" options="{'no_create': True}" width="150px"/>
                <field name="employee_id" readonly="1" options="{'no_create': True}" width="150px"/>
                <field name="fuel_amount" sum="Total Fuel" width="100px"/>
                <field name="is_fueled" width="80px"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_fuel_trip_form" model="ir.ui.view">
        <field name="name">fuel.trip.form</field>
        <field name="model">fuel.trip</field>
        <field name="arch" type="xml">
            <form string="Fuel Trip" create="0" delete="0">
                <sheet>
                    <group>
                        <group>
                            <field name="date" readonly="1"/>
                            <field name="trip_type" readonly="1"/>
                            <field name="approval_id" readonly="1" options="{'no_create': True}"/>
                        </group>
                        <group>
                            <field name="vehicle_id" readonly="1" options="{'no_create': True}"/>
                            <field name="employee_id" readonly="1" options="{'no_create': True}"/>
                            <field name="fuel_amount"/>
                            <field name="is_fueled"/>
                        </group>
                    </group>
                    <group string="მივლინების დეტალები">
                        <field name="trip_purpose" readonly="1" nolabel="1" placeholder="მივლინების მიზანი..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_fuel_trip" model="ir.actions.act_window">
        <field name="name">მივლინება (საწვავის ხარჯი)</field>
        <field name="res_model">fuel.trip</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Record a new fuel expense for a trip.
            </p>
        </field>
    </record>

    <!-- Menu Structure -->
    <menuitem id="menu_fuel_trip_main"
              name="მივლინება (საწვავის ხარჯი)"
              parent="fleet.menu_root"
              action="action_fuel_trip"
              sequence="10"/>
</odoo>
