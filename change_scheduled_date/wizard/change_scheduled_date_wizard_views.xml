<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="change_scheduled_date_wizard_view_form" model="ir.ui.view">
        <field name="name">change.scheduled.date.wizard.form</field>
        <field name="model">change.scheduled.date.wizard</field>
        <field name="arch" type="xml">
            <form string="Change Scheduled Date">
                <group>
                    <field name="new_scheduled_date"/>
                </group>
                <footer>
                    <button name="action_update_date" string="Update" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
