<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Wizard Form View -->
    <record id="view_doc_pdf_wizard_form" model="ir.ui.view">
        <field name="name">doc.pdf.wizard.form</field>
        <field name="model">doc.pdf.wizard</field>
        <field name="arch" type="xml">
            <form string="Convert DOCX to PDF">
                <group invisible="state == 'converted'">
                    <group>
                        <field name="name" placeholder="Document Name" invisible="1"/>
                        <field name="docx_file" filename="docx_filename" widget="binary"/>
                        <field name="docx_filename" invisible="1"/>
                        <field name="state" invisible="1"/>
                    </group>
                </group>
                
                <group invisible="state == 'upload'">
                    <group>
                        <field name="name" readonly="1"/>
                        <field name="conversion_date" readonly="1"/>
                    </group>
                </group>
                
                <!-- Hidden fields -->
                <field name="pdf_file" invisible="1"/>
                <field name="pdf_filename" invisible="1"/>
                <field name="source_model" invisible="1"/>
                <field name="source_res_id" invisible="1"/>
                
                <footer>
                    <button string="Convert to PDF" 
                            name="action_convert_to_pdf" 
                            type="object" 
                            class="btn-primary"
                            invisible="state == 'converted'"/>
                    
                    <button string="Close" 
                            class="btn-secondary" 
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Action to open wizard -->
    <record id="action_doc_pdf_wizard" model="ir.actions.act_window">
        <field name="name">Convert DOCX to PDF</field>
        <field name="res_model">doc.pdf.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="base.model_res_users"/>
    </record>

</odoo>

