<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ინსპექტირების დასკვნა (Daskvna) Report -->
    <record id="action_report_inspektireba_daskvna" model="ir.actions.report">
        <field name="name">ინსპექტირების დასკვნა</field>
        <field name="model">inspektireba</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">inspektireba_module.report_inspektireba_daskvna</field>
        <field name="report_file">inspektireba_module.report_inspektireba_daskvna</field>
        <field name="print_report_name">'ინსპექტირების დასკვნა - %s' % (object.name)</field>
        <field name="binding_model_id" ref="model_inspektireba"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_inspektireba_daskvna">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.basic_layout">
                    <div class="page" style="font-family: 'Sylfaen', sans-serif; font-size: 14px; margin-top: 50px;">
                        
                        <div style="text-align: center; font-weight: bold; margin-bottom: 20px; font-size: 16px;">
                            ინსპექტირების ჯგუფის დასკვნა № <t t-esc="doc.name"/>
                        </div>

                        <div style="text-align: right; font-weight: bold; margin-bottom: 30px;">
                            <t t-if="doc.date">
                                <t t-esc="doc.date.strftime('%d.%m.%Y')"/>
                            </t>
                        </div>

                        <div style="text-align: justify; margin-bottom: 20px;">
                            <t t-if="doc.paragraph_1">
                                <t t-foreach="doc.paragraph_1.split('\n')" t-as="line">
                                    <t t-esc="line"/><br/>
                                </t>
                            </t>
                        </div>

                        <div style="text-align: justify; margin-bottom: 20px;">
                            <t t-if="doc.paragraph_2">
                                <t t-foreach="doc.paragraph_2.split('\n')" t-as="line">
                                    <t t-esc="line"/><br/>
                                </t>
                            </t>
                        </div>

                        <div style="text-align: justify; margin-bottom: 10px; font-weight: bold;" t-if="doc.paragraph_3">
                            დასკვნა :
                        </div>

                        <div style="text-align: justify; margin-bottom: 40px;">
                            <t t-if="doc.paragraph_3">
                                <t t-foreach="doc.paragraph_3.split('\n')" t-as="line">
                                    <t t-esc="line"/><br/>
                                </t>
                            </t>
                        </div>

                        <div style="margin-bottom: 20px; font-weight: bold; margin-top: 40px;">
                            ინსპექტირების ჯგუფის წევრები:
                        </div>

                        <table style="width: 100%; text-align: left; margin-top: 20px; page-break-inside: avoid;">
                            <t t-foreach="doc.approver_line_ids" t-as="line">
                                <tr>
                                    <td style="padding-bottom: 30px; width: 60%;">
                                        <t t-esc="line.user_id.name"/>
                                    </td>
                                    <td style="padding-bottom: 30px; width: 40%;">
                                        <div style="border-bottom: 1px solid black; width: 100%; height: 15px;"></div>
                                    </td>
                                </tr>
                            </t>
                        </table>

                    </div>
                </t>
            </t>
        </t>
    </template>

    <!-- ინსპექტირების დასკვნა – ტრანსპორტი (Transport Daskvna) Report -->
