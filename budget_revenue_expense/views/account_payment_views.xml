<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inherit account.payment form view to add revenue_code field -->
    <record id="view_account_payment_form_revenue_code" model="ir.ui.view">
        <field name="name">account.payment.form.revenue.code</field>
        <field name="model">account.payment</field>
        <field name="inherit_id" ref="account.view_account_payment_form"/>
        <field name="arch" type="xml">
            <!-- Add revenue_code field after journal_id -->
            <field name="journal_id" position="after">
                <field name="revenue_code"
                       domain="[('plan_id', 'child_of', 2)]"/>
            </field>
        </field>
    </record>
</odoo>
