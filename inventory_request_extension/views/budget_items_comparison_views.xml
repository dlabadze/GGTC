<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_budget_items_comparison_list" model="ir.ui.view">
        <field name="name">budget.items.comparison.list</field>
        <field name="model">budget.items.comparison</field>
        <field name="arch" type="xml">
            <list string="Budget Items Comparison">
                <field name="category_id"/>
                <field name="default_budget_analytic"/>
                <field name="request_budget_analytic"/>
                <field name="amount"/>
                <field name="department_id"/>
            </list>
        </field>
    </record>

    <record id="action_budget_items_comparison" model="ir.actions.act_window">
        <field name="name">Comparison of budget items</field>
        <field name="res_model">budget.items.comparison</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_budget_items_comparison_list"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No budget items comparison found
            </p>
            <p>
                This report shows inventory lines where the budget analytic account 
                doesn't match the default budget analytic from the category.
            </p>
        </field>
    </record>
</odoo>

