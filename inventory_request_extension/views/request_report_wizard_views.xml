<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_request_report_wizard_form" model="ir.ui.view">
        <field name="name">request.report.wizard.form</field>
        <field name="model">request.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Request Report">
                <group>
                    <field name="budget_request_id" required="1"/>
                    <field name="department_id" required="1"/>
                </group>
                <footer>
                    <button name="action_generate_report" string="Generate Report" type="object" class="oe_highlight"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_request_report_wizard" model="ir.actions.act_window">
        <field name="name">Request Report</field>
        <field name="res_model">request.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>

