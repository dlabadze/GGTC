<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_request_report_line_list" model="ir.ui.view">
        <field name="name">request.report.line.list</field>
        <field name="model">request.report.line</field>
        <field name="arch" type="xml">
            <list string="Request Report Lines" decoration-danger="diff_amount &lt; 0 or diff_quantity &lt; 0">
                <field name="category_id"/>
                <field name="budget_amount"/>
                <field name="budget_quantity"/>
                <field name="actual_amount"/>
                <field name="actual_quantity"/>
                <field name="diff_amount"/>
                <field name="diff_quantity"/>
                <field name="is_negative" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="action_request_report_line" model="ir.actions.act_window">
        <field name="name">Request Report</field>
        <field name="res_model">request.report.line</field>
        <field name="view_mode">list</field>
    </record>
</odoo>

