<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ganawileba_wizard_form" model="ir.ui.view">
        <field name="name">ganawileba.wizard.form</field>
        <field name="model">ganawileba.wizard</field>
        <field name="arch" type="xml">
            <form string="Select User for Ganawileba">
                <group>
                    <field name="request_id" invisible="1"/>
                    <field name="user_id" required="1"/>
                </group>
                <footer>
                    <button name="action_confirm" string="Confirm" type="object" class="oe_highlight"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_ganawileba_wizard" model="ir.actions.act_window">
        <field name="name">Select User for Ganawileba</field>
        <field name="res_model">ganawileba.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>

