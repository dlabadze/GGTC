<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ganfaseba_wizard_form" model="ir.ui.view">
        <field name="name">ganfaseba.wizard.form</field>
        <field name="model">ganfaseba.wizard</field>
        <field name="arch" type="xml">
            <form string="Select User for ganfaseba">
                <group>
                    <field name="request_line_ids" invisible="0" widget="many2many_tags"/>
                    <field name="user_id" required="1"/>
                </group>
                <footer>
                    <button name="action_confirm" string="Confirm" type="object" class="oe_highlight"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_ganfaseba_wizard" model="ir.actions.act_window">
        <field name="name">Select User for ganfaseba</field>
        <field name="res_model">ganfaseba.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>