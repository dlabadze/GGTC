<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Rule: Base User sees only followed records -->
        <record id="moxsenebiti_rule_follower_only" model="ir.rule">
            <field name="name">Moxsenebiti: Follower Only</field>
            <field name="model_id" ref="model_moxsenebiti"/>
            <field name="domain_force">[('message_is_follower', '=', True)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- Rule: Payroll Manager sees ALL records -->
        <!-- Note: This overrides the restriction for users who have this group -->
        <record id="moxsenebiti_rule_payroll_manager_all" model="ir.rule">
            <field name="name">Moxsenebiti: Payroll Manager See All</field>
            <field name="model_id" ref="model_moxsenebiti"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('hr_payroll.group_hr_payroll_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>
    </data>
</odoo>
