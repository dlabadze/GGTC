<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_moxsenebiti_reinitiate_form" model="ir.ui.view">
        <field name="name">moxsenebiti.reinitiate.form</field>
        <field name="model">moxsenebiti.reinitiate</field>
        <field name="arch" type="xml">
            <form string="თავიდან ინიცირება (დაბრუნება)">
                <sheet>
                    <group>
                        <field name="reason" placeholder="მიუთითეთ რატომ აბრუნებთ დრაფტში..."/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_reinitiate_confirm" string="დაბრუნება" type="object" class="btn-danger"/>
                    <button special="cancel" string="გაუქმება" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
