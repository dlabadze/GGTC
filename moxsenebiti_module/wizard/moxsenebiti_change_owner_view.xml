<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_moxsenebiti_change_owner_form" model="ir.ui.view">
        <field name="name">moxsenebiti.change.owner.form</field>
        <field name="model">moxsenebiti.change.owner</field>
        <field name="arch" type="xml">
            <form string="მფლობელის შეცვლა">
                <group>
                    <field name="moxsenebiti_id" invisible="1"/>
                    <field name="new_owner_id" required="1" options="{'no_create': True}"/>
                </group>
                <footer>
                    <button name="action_confirm" string="გადაწერა" type="object" class="btn-primary"/>
                    <button string="გაუქმება" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
