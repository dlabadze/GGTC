<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Purchase Requisition Payment Wizard Form View -->
    <record id="view_purchase_requisition_payment_wizard_form" model="ir.ui.view">
        <field name="name">purchase.requisition.payment.wizard.form</field>
        <field name="model">purchase.requisition.payment.wizard</field>
        <field name="arch" type="xml">
            <form string="Select Purchase Requisition">
                <group>
                    <group>
                        <field name="st_line_id" readonly="1"/>
                        <field name="partner_id" readonly="1"/>
                        <field name="transaction_amount" readonly="1"/>
                        <field name="currency_id" invisible="1"/>
                        <field name="purchase_requisition_ids" invisible="1"/>
                    </group>
                    <group>
                        <field name="purchase_requisition_id"
                               options="{'no_create': True, 'no_open': True}"/>
                        <field name="current_paid_amount" readonly="1"/>
                        <field name="new_paid_amount" readonly="1"/>
                    </group>
                </group>
                <footer>
                    <button string="Confirm and Validate"
                            name="action_confirm"
                            type="object"
                            class="btn-primary"/>
                    <button string="Cancel"
                            name="action_cancel"
                            type="object"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Action for opening the wizard -->
    <record id="action_purchase_requisition_payment_wizard" model="ir.actions.act_window">
        <field name="name">Select Purchase Requisition</field>
        <field name="res_model">purchase.requisition.payment.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="account_accountant.model_bank_rec_widget"/>
    </record>
</odoo>
