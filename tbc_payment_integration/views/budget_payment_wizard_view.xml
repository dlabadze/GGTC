<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_budget_payment_wizard_form" model="ir.ui.view">
        <field name="name">budget.payment.wizard.form</field>
        <field name="model">budget.payment.wizard</field>
        <field name="arch" type="xml">
            <form string="ბიუჯეტის გადახდა">
                <group>
                    <group>
                        <field name="st_line_id" readonly="1"/>
                        <field name="transaction_amount" readonly="1"/>
                        <field name="currency_id" invisible="1"/>
                    </group>
                    <group>
                        <field name="budget_analytic_id"
                               options="{'no_create': True, 'no_open': True}"/>
                        <field name="budget_line_id"
                               options="{'no_create': True, 'no_open': True}"/>
                        <field name="current_paim_am" readonly="1"/>
                        <field name="new_paim_am" readonly="1"/>
                    </group>
                </group>
                <footer>
                    <button string="დადასტურება"
                            name="action_confirm"
                            type="object"
                            class="btn-primary"/>
                    <button string="გაუქმება"
                            name="action_cancel"
                            type="object"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
