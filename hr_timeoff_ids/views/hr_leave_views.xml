<odoo>
    <!-- Inherit the manager form and place fields exactly where requested -->
    <record id="hr_leave_view_form_manager_inherit_ids" model="ir.ui.view">
        <field name="name">hr.leave.view.form.manager.ids.inherit</field>
        <field name="model">hr.leave</field>
        <field name="inherit_id" ref="hr_holidays.hr_leave_view_form_manager"/>
        <field name="arch" type="xml">

            <!-- Add Time Off ID ABOVE the Employee field -->
            <xpath expr="//field[@name='employee_id']" position="before">
                <field name="timeoff_id" readonly="1"/>
            </xpath>

            <!-- Add Time Off Type ID UNDER the Time Off Type -->
            <xpath expr="//field[@name='holiday_status_id']" position="after">
                <field name="timeoff_type_seq" readonly="1"/>
            </xpath>

        </field>
    </record>
</odoo>
