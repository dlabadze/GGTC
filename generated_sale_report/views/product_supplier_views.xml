<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="generated_sale_report_product_template_form_supplier" model="ir.ui.view">
        <field name="name">generated.sale.report.product.template.form.supplier</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product_extend.product_template_form_view_extension"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='product_extensions']/group[1]/group[1]" position="inside">
                <field name="supplier_id"/>
                <field name="litri"/>
            </xpath>
        </field>
    </record>
</odoo>
