<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_generate_sale_report_wizard_form" model="ir.ui.view">
        <field name="name">generate.sale.report.wizard.form</field>
        <field name="model">generate.sale.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Generate Sale Report">
                <group>
                    <field name="date_start"/>
                    <field name="date_end"/>
                </group>
                <footer>
                    <button name="action_generate" string="Generate" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_generate_sale_report_wizard" model="ir.actions.act_window">
        <field name="name">გაყიდვების რეპორტი</field>
        <field name="res_model">generate.sale.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_generate_sale_report"
        name="გაყიდვების რეპორტი"
        action="action_generate_sale_report_wizard"
        sequence="50"/>
</odoo>
