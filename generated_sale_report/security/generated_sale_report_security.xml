<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_sale_report" model="ir.module.category">
        <field name="name">Sale Report</field>
        <field name="description">Helps you manage sales reports</field>
        <field name="sequence">10</field>
    </record>

    <record id="group_sale_report_manager" model="res.groups">
        <field name="name">Manager</field> <field name="category_id" ref="module_category_sale_report"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>
</odoo>