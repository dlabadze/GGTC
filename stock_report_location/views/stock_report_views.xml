                <field name="outgoing_qty" string="გასავალი" sum="გასავალი"/>
                <field name="final_qty" string="საბოლოო ნაშთი" sum="საბოლოო რაოდენობა"/>
                <field name="unit_price" sum="Cost" column_invisible="1"/>
                <field name="initial_amount" string="საწყისი თანხა" sum="საწყისი თანხა" digits="[16, 4]"/>
                <field name="incoming_amount" string="შემოსავალი თანხა" sum="შემოსავალი თანხა" digits="[16, 4]"/>
