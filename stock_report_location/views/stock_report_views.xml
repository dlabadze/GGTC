    <record id="view_gza_stock_location_report_list_no_category_amount" model="ir.ui.view">
        <field name="name">gza.stock.location.report.list.no.category.amount</field>
        <field name="model">gza.stock.location.report</field>
        <field name="arch" type="xml">
            <list string="Stock Report by Location">
                <field name="product_name" string="პროდუქცია"/>
                <field name="stock_valuation_account_id" string="Stock Valuation Account"/>
                <field name="internal_ref" string="პროდუქციის კოდი"/>
                <field name="location_id" string="ლოკაცია"/>
                <field name="unique_location_id" string="ლოკაციის კოდი"/>
                <field name="uom_name" string="ერთეული"/>
