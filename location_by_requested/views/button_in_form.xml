<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_inventory_request_inherit_action" model="ir.ui.view">
        <field name="name">inventory.request.view.form.button</field>
        <field name="model">inventory.request</field>
        <field name="inherit_id" ref="inventory_requests.view_inventory_request_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form/header" position="inside">
                <button
                        name="%(location_by_requested.server_action_location_from_users)d"
                        string="Get location"
                        type="action"
                        class="oe_highlight"/>
            </xpath>
        </field>
    </record>
</odoo>