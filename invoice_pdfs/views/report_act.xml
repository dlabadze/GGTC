<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="action_download_separate_invoices" model="ir.actions.server">
            <field name="name">საურავი გგს</field>
            <field name="model_id" ref="account.model_account_move"/>
            <field name="binding_model_id" ref="account.model_account_move"/>
            <field name="binding_view_types">list,form</field>
            <field name="state">code</field>
            <field name="code">
    if records:
        action = records.action_download_separate_pdfs()
            </field>
        </record>

        <record id="action_download_separate_invoices_transport" model="ir.actions.server">
            <field name="name">ტრანსპორტირება გგს</field>
            <field name="model_id" ref="account.model_account_move"/>
            <field name="binding_model_id" ref="account.model_account_move"/>
            <field name="binding_view_types">list,form</field>
            <field name="state">code</field>
            <field name="code">
    if records:
        action = records.action_download_separate_pdfs_transport()
            </field>
        </record>

        <record id="action_download_separate_invoices_other" model="ir.actions.server">
            <field name="name">სხვა მომსახურება</field>
            <field name="model_id" ref="account.model_account_move"/>
            <field name="binding_model_id" ref="account.model_account_move"/>
            <field name="binding_view_types">list,form</field>
            <field name="state">code</field>
            <field name="code">
    if records:
        action = records.action_download_separate_pdfs_other()
            </field>
        </record>

     <record id="paperformat_no_margins" model="report.paperformat">
            <field name="name">No Margins</field>
            <field name="default" eval="False"/>
            <field name="format">A4</field>
            <field name="page_height">0</field>
            <field name="page_width">0</field>
            <field name="margin_top">5</field>
            <field name="margin_bottom">5</field>
            <field name="margin_left">5</field>
            <field name="margin_right">5</field>
            <field name="orientation">Portrait</field>
     </record>

        <record id="action_report_invoice_report" model="ir.actions.report">
            <field name="name">Invoice Report</field>
            <field name="model">account.move</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">invoice_pdfs.report_invoice_custom</field>
            <field name="report_file">invoice_pdfs.report_invoice_custom</field>
            <field name="binding_model_id" ref="account.model_account_move"/>
            <field name="binding_type">report</field>
            <field name="paperformat_id" ref="invoice_pdfs.paperformat_no_margins"/>
        </record>
        <record id="action_report_invoice_transport_report" model="ir.actions.report">
            <field name="name">Invoice Report Transport</field>
            <field name="model">account.move</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">invoice_pdfs.report_invoice_transport_custom</field>
            <field name="report_file">invoice_pdfs.report_invoice_transport_custom</field>
            <field name="binding_model_id" ref="account.model_account_move"/>
            <field name="binding_type">report</field>
            <field name="paperformat_id" ref="invoice_pdfs.paperformat_no_margins"/>
        </record>
        <record id="action_report_invoice_other_report" model="ir.actions.report">
            <field name="name">Invoice Report Other Service</field>
            <field name="model">account.move</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">invoice_pdfs.report_invoice_other_custom</field>
            <field name="report_file">invoice_pdfs.report_invoice_other_custom</field>
            <field name="binding_model_id" ref="account.model_account_move"/>
            <field name="binding_type">report</field>
            <field name="paperformat_id" ref="invoice_pdfs.paperformat_no_margins"/>
        </record>
    </data>
</odoo>
