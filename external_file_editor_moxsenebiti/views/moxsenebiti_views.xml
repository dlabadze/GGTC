<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_moxsenebiti_form_inherit" model="ir.ui.view">
        <field name="name">moxsenebiti.form.inherit.external.file.editor</field>
        <field name="model">moxsenebiti</field>
        <field name="inherit_id" ref="moxsenebiti_module.view_moxsenebiti_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_edit_file" 
                        string="ფაილის რედაქტირება" 
                        type="object" 
                        class="oe_highlight"
                        invisible="not word_file"/>
            </xpath>
        </field>
    </record>
</odoo>
