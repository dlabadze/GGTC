<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Kanban View -->
    <record id="view_inventory_line_kanban" model="ir.ui.view">
        <field name="name">inventory.line.kanban</field>
        <field name="model">inventory.line</field>
        <field name="arch" type="xml">
            <kanban default_group_by="stage_id" class="o_kanban_small_column">
                <field name="stage_id"/>
                <field name="tag_ids"/>
                <field name="product_id"/>
                <field name="quantity"/>
                <field name="uom_id"/>
                <field name="unit_price"/>
                <field name="amount"/>
                <field name="request_id"/>
                <field name="expected_date"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="oe_kanban_content">
                                <div class="o_kanban_record_top">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title">
                                            <field name="name"/>
                                        </strong>
                                    </div>
                                </div>
                                <div class="o_kanban_record_body">
                                    <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                                    <div>
                                        <i class="fa fa-cube"/> <field name="product_id"/>
                                    </div>
                                    <div>
                                        <i class="fa fa-calculator"/> <field name="quantity"/> <field name="uom_id"/>
                                    </div>
                                    <div>
                                        <i class="fa fa-money"/> <field name="unit_price" widget="monetary"/>
                                    </div>
                                    <div>
                                        <i class="fa fa-file-text-o"/> <field name="request_id"/>
                                    </div>
                                </div>
                                <div class="o_kanban_record_bottom">
                                    <div class="oe_kanban_bottom_left">
                                        <field name="expected_date"/>
                                    </div>
                                    <div class="oe_kanban_bottom_right">
                                        <strong>
                                            <field name="amount" widget="monetary"/>
                                        </strong>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- List View -->
    <record id="view_inventory_line_tree" model="ir.ui.view">
        <field name="name">inventory.line.tree</field>
        <field name="model">inventory.line</field>
        <field name="arch" type="xml">
            <list>
                <field name="request_id"/>
                <field name="product_id"/>
                <field name="name"/>
                <field name="quantity"/>
                <field name="uom_id"/>
                <field name="unit_price" widget="monetary"/>
                <field name="amount" widget="monetary"/>
                <field name="expected_date"/>
                <field name="stage_id"/>
                <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                <field name="request_stage_id"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_inventory_line_form" model="ir.ui.view">
        <field name="name">inventory.line.form</field>
        <field name="model">inventory.line</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="stage_id" widget="statusbar" options="{'clickable': '1'}"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                        <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}" placeholder="Tags..."/>
                    </div>
                    <group>
                        <group>
                            <field name="request_id"/>
                            <field name="product_id"/>
                            <field name="quantity"/>
                            <field name="uom_id"/>
                        </group>
                        <group>
                            <field name="sequence"/>
                            <field name="expected_date"/>
                            <field name="request_stage_id"/>
                        </group>
                    </group>
                    <group>
                        <group string="Pricing">
                            <field name="unit_price" widget="monetary"/>
                            <field name="amount" widget="monetary" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Notes">
                            <field name="notes" placeholder="Add notes..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_inventory_line_search" model="ir.ui.view">
        <field name="name">inventory.line.search</field>
        <field name="model">inventory.line</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="product_id"/>
                <field name="request_id"/>
                <field name="stage_id"/>
                <field name="tag_ids"/>
                <field name="unit_price"/>
                <field name="amount"/>
                <separator/>
                <filter name="group_by_stage" string="Stage"
                        context="{'group_by':'stage_id'}"/>
                <filter name="group_by_product" string="Product"
                        context="{'group_by':'product_id'}"/>
                <filter name="group_by_request" string="Request"
                        context="{'group_by':'request_id'}"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter string="Stage" name="group_stage"
                            context="{'group_by':'stage_id'}"/>
                    <filter string="Product" name="group_product"
                            context="{'group_by':'product_id'}"/>
                    <filter string="Request" name="group_request"
                            context="{'group_by':'request_id'}"/>
                    <filter string="Expected Date" name="group_expected_date"
                            context="{'group_by':'expected_date'}"/>
                </group>
            </search>
        </field>
    </record>
</odoo>