<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_stock_valuation_import_wizard_form" model="ir.ui.view">
        <field name="name">stock.valuation.import.wizard.form</field>
        <field name="model">stock.valuation.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Import Product Costs — Jan 1st Backfill">
                <sheet>
                    <div class="oe_title">
                        <h1>Import Product Costs &amp; Backfill Valuation</h1>
                    </div>

                    <!-- Result banner (visible when done) -->
                    <div class="alert alert-success mb-3" role="alert"
                         invisible="state != 'done'">
                        <strong>✅ Complete</strong><br/>
                        <field name="result_message" readonly="1"/>
                    </div>

                    <group string="Settings" invisible="state == 'done'">
                        <group>
                            <field name="excel_file"
                                   filename="excel_filename"
                                   widget="binary"/>
                            <field name="excel_filename" invisible="1"/>
                        </group>
                        <group>
                            <field name="target_date"/>
                            <field name="cleanup_today"/>
                        </group>
                    </group>

                    <group string="Expected Excel Columns" invisible="state == 'done'">
                        <div colspan="2">
                            <table class="table table-sm table-bordered" style="max-width:620px">
                                <thead class="table-light">
                                    <tr><th>Column</th><th>Description</th><th>Required</th></tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td><code>id</code></td>
                                        <td>Odoo External ID</td>
                                        <td>✅ Yes</td>
                                    </tr>
                                    <tr>
                                        <td><code>standard_price</code></td>
                                        <td>Unit cost (float)</td>
                                        <td>✅ Yes</td>
                                    </tr>
                                    <tr>
                                        <td><code>დებეტი</code> / <code>debit</code></td>
                                        <td>Debit account code (e.g. 1620, 2197, 1640)</td>
                                        <td>⚠️ Recommended</td>
                                    </tr>
                                    <tr>
                                        <td><code>კრედიტი</code> / <code>credit</code></td>
                                        <td>Credit account code (e.g. 1612)</td>
                                        <td>⚠️ Recommended</td>
                                    </tr>
                                </tbody>
                            </table>
                            <p class="text-muted mt-2" style="font-size:0.85em">
                                The wizard will: <strong>(1)</strong> update standard_price,
                                <strong>(2)</strong> fix Jan 1st valuation layer costs,
                                <strong>(3)</strong> delete any existing journal entry for each layer,
                                <strong>(4)</strong> create a new <em>posted</em> journal entry
                                with the correct date and accounts,
                                <strong>(5)</strong> delete today's accidental revaluation moves.
                            </p>
                        </div>
                    </group>

                    <field name="state" invisible="1"/>
                </sheet>

                <footer>
                    <button name="action_import_and_fix"
                            string="▶  Run Import &amp; Create Journal Entries"
                            type="object"
                            class="btn-primary"
                            confirm="This will update costs, recreate all Jan 1st journal entries, and delete today's spurious revaluation moves. Continue?"
                            invisible="state == 'done'"/>

                    <button name="action_reset"
                            string="↩  Run Again"
                            type="object"
                            class="btn-secondary"
                            invisible="state != 'done'"/>

                    <button string="Close" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_stock_valuation_import_wizard" model="ir.actions.act_window">
        <field name="name">Import Product Costs</field>
        <field name="res_model">stock.valuation.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="view_id" ref="view_stock_valuation_import_wizard_form"/>
    </record>

</odoo>