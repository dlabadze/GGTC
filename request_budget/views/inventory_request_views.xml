<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Kanban View -->
    <record id="view_budgeting_request_kanban" model="ir.ui.view">
        <field name="name">budgeting.request.kanban</field>
        <field name="model">budgeting.request</field>
        <field name="arch" type="xml">
            <kanban default_group_by="stage_id" class="o_kanban_small_column" 
                    group_create="false" group_delete="false" group_edit="false"
                    archivable="false" quick_create="false">
                <field name="id"/>
                <field name="name"/>
                <field name="stage_id"/>
                <field name="requested_by"/>
                <field name="request_date"/>
                <field name="total_lines"/>
                <field name="priority"/>
                <field name="tag_ids"/>
                <field name="description"/>
                <progressbar field="stage_id" colors='{"draft": "info", "confirmed": "warning", "approved": "success", "rejected": "danger"}'/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="oe_kanban_content">
                                <div class="o_kanban_record_top">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title">
                                            <field name="name"/>
                                        </strong>
                                    </div>
                                    <div class="o_kanban_record_badges">
                                        <field name="priority" widget="priority"/>
                                    </div>
                                </div>
                                <div class="o_kanban_record_body">
                                    <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                                    <div class="o_kanban_record_subtitle">
                                        <field name="description"/>
                                    </div>
                                    <div>
                                        <i class="fa fa-user"/> <field name="requested_by"/>
                                    </div>
                                    <div>
                                        <i class="fa fa-calendar"/> <field name="request_date"/>
                                    </div>
                                    <div>
                                        <i class="fa fa-list"/> <field name="total_lines"/> lines
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- List View -->
    <record id="view_budgeting_request_list" model="ir.ui.view">
        <field name="name">budgeting.request.list</field>
        <field name="model">budgeting.request</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="description"/>
                <field name="requested_by"/>
                <field name="department_id"/>
                <field name="request_date"/>
                <field name="priority" widget="priority"/>
                <field name="stage_id"/>
                <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                <field name="total_lines"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_budgeting_request_form" model="ir.ui.view">
        <field name="name">budgeting.request.form</field>
        <field name="model">budgeting.request</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="stage_id" widget="statusbar" options="{'clickable': '1'}"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                        <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}" placeholder="Tags..."/>
                    </div>
                    <group>
                        <group>
                            <field name="request_date"/>
                            <field name="requested_by"/>
                            <field name="department_id"/>
                        </group>
                        <group>
                            <field name="priority" widget="priority"/>
                            <field name="total_lines"/>
                        </group>
                    </group>
                    <group>
                        <field name="description" placeholder="Add request description..."/>
                    </group>
                    <notebook>
                        <page string="Budgeting Lines">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="product_id"/>
                                    <field name="name"/>
                                    <field name="quantity"/>
                                    <field name="uom_id"/>
                                    <field name="expected_date"/>
                                    <field name="stage_id"/>
                                    <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                                    <field name="notes"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_budgeting_request_search" model="ir.ui.view">
        <field name="name">budgeting.request.search</field>
        <field name="model">budgeting.request</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="description"/>
                <field name="requested_by"/>
                <field name="department_id"/>
                <field name="stage_id"/>
                <field name="tag_ids"/>
                <separator/>
                <filter name="my_requests" string="My Requests"
                        domain="[('requested_by','=',uid)]"/>
                <filter name="high_priority" string="High Priority"
                        domain="[('priority','in',['2','3'])]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter string="Stage" name="group_stage"
                            context="{'group_by':'stage_id'}"/>
                    <filter string="Requested By" name="group_requester"
                            context="{'group_by':'requested_by'}"/>
                    <filter string="Department" name="group_department"
                            context="{'group_by':'department_id'}"/>
                    <filter string="Priority" name="group_priority"
                            context="{'group_by':'priority'}"/>
                    <filter string="Request Date" name="group_date"
                            context="{'group_by':'request_date'}"/>
                </group>
            </search>
        </field>
    </record>


</odoo>