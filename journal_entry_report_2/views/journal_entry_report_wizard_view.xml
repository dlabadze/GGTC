<odoo>
  <record id="view_journal_entry_report_wizard_2" model="ir.ui.view">
    <field name="name">journal.entry.report.wizard.2.form</field>
    <field name="model">journal.entry.report.wizard.2</field>
    <field name="arch" type="xml">
      <form string="Journal Entry Report">
        <group>
          <field name="start_date"/>
          <field name="end_date"/>
          <field name="debit_accounts" widget="many2many_tags"/>
          <field name="credit_accounts" widget="many2many_tags"/>
        </group>
        <footer>
          <button name="action_generate_report" type="object" string="Print Report" class="btn-primary"/>
          <button string="Cancel" class="btn-secondary" special="cancel"/>
        </footer>
      </form>
    </field>
  </record>

  <record id="action_journal_entry_report_wizard_2" model="ir.actions.act_window">
    <field name="name">ორი</field>
    <field name="res_model">journal.entry.report.wizard.2</field>
    <field name="view_mode">form</field>
    <field name="target">new</field>
  </record>

  <menuitem id="menu_journal_entry_report_root_2" name="ორი" parent="account.menu_finance_entries"/>
  <menuitem id="menu_journal_entry_report_2" name="ორი" parent="menu_journal_entry_report_root_2"
            action="action_journal_entry_report_wizard_2"/>
</odoo>
