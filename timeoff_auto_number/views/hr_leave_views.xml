<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        
        <record id="hr_leave_view_form_add_nomeri" model="ir.ui.view">
            <field name="name">hr.leave.form.add.nomeri</field>
            <field name="model">hr.leave</field>
            <field name="inherit_id" ref="hr_holidays.hr_leave_view_form"/>
            <field name="arch" type="xml">
                <field name="employee_id" position="after">
                    <field name="nomeri" readonly="1"/>
                </field>
            </field>
        </record>
        
        <record id="hr_leave_view_tree_add_nomeri" model="ir.ui.view">
            <field name="name">hr.leave.tree.add.nomeri</field>
            <field name="model">hr.leave</field>
            <field name="inherit_id" ref="hr_holidays.hr_leave_view_tree"/>
            <field name="arch" type="xml">
                <field name="employee_id" position="before">
                    <field name="nomeri" optional="show"/>
                </field>
            </field>
        </record>
        
    </data>
</odoo>