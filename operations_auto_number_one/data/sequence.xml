<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Sequence for X Operations -->
        <record id="seq_x_operations" model="ir.sequence">
            <field name="name">X Operations Sequence</field>
            <field name="code">x_operations.sequence</field>
            <field name="prefix"></field>
            <field name="suffix">/1</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
            <field name="padding">0</field>
            <field name="implementation">standard</field>
            <field name="use_date_range">True</field>
            <field name="date_range_ids" eval="[(0, 0, {
                'date_from': '2025-01-01',
                'date_to': '2025-12-31',
                'number_next': 1
            })]"/>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>
