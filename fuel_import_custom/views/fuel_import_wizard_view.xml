<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Import Wizard Form View -->
    <record id="view_fuel_import_wizard_form" model="ir.ui.view">
        <field name="name">fuel.import.wizard.form</field>
        <field name="model">fuel.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Import Fuel Logs">
                <sheet>
                    <div class="oe_title">
                        <h1>🚗 Fuel Filling Log Import</h1>
                        <h2>საწვავის ჩასხმის ჟურნალის იმპორტი</h2>
                    </div>
                    
                    <!-- File Upload Section -->
                    <group name="file_upload">
                        <field name="file_data" 
                               filename="file_name" 
                               required="1"/>
                        <field name="file_name" invisible="1"/>
                    </group>
                    
                    <!-- Import Button -->
                    <div class="text-center mt-3">
                        <button name="action_import_fuel_logs" 
                                string="🚀 Import Fuel Data" 
                                type="object" 
                                class="btn-primary btn-lg"/>
                    </div>
                    
                    <!-- Instructions -->
                    <div class="alert alert-info mt-4" role="alert">
                        <h4><i class="fa fa-info-circle"/> 📊 File Format Requirements:</h4>
                        
                        <div class="row">
                            <div class="col-md-6">
                                <h5>✅ Supported Formats:</h5>
                                <ul>
                                    <li><strong>.xlsx</strong> (Excel 2007+)</li>
                                    <li><strong>.xls</strong> (Excel 97-2003)</li>
                                    <li><strong>.csv</strong> (Comma Separated)</li>
                                </ul>
                            </div>
                            <div class="col-md-6">
                                <h5>📋 Expected Columns:</h5>
                                <ul>
                                    <li><strong>A:</strong> Description (აღწერა)</li>
                                    <li><strong>B:</strong> Date (თარიღი)</li>
                                    <li><strong>C:</strong> Vehicle (მანქანა)</li>
                                    <li><strong>D:</strong> Fuel Amount (ლიტრი)</li>
                                </ul>
                            </div>
                        </div>
                        
                        <h5>📋 Data Example:</h5>
                        <table class="table table-sm table-bordered">
                            <thead class="table-light">
                                <tr>
                                    <th>A</th>
                                    <th>B</th>
                                    <th>C</th>
                                    <th>D</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>ივნისი</td>
                                    <td>6/27/2025</td>
                                    <td>GG775GR</td>
                                    <td>44.0</td>
                                </tr>
                                <tr>
                                    <td>ივნისი</td>
                                    <td>6/26/2025</td>
                                    <td>QZ927QQ</td>
                                    <td>30.99</td>
                                </tr>
                            </tbody>
                        </table>
                        
                        <div class="alert alert-success">
                            <strong>🎯 Import Features:</strong>
                            <ul class="mb-0">
                                <li>✅ Auto-detects file format</li>
                                <li>✅ Auto-skips header rows</li>
                                <li>✅ Creates records in BOTH Studio models</li>
                                <li>✅ Handles multiple date formats</li>
                                <li>✅ 100% bulletproof parsing</li>
                            </ul>
                        </div>
                    </div>
                </sheet>
            </form>
        </field>
    </record>
    
    <!-- Import Wizard Action -->
    <record id="action_fuel_import_wizard" model="ir.actions.act_window">
        <field name="name">🚀 Import Fuel Data</field>
        <field name="res_model">fuel.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="view_id" ref="view_fuel_import_wizard_form"/>
    </record>
</odoo>