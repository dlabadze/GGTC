<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- list/List View for Fleet Branch -->
    <record id="view_fleet_branch_list" model="ir.ui.view">
        <field name="name">fleet.branch.list</field>
        <field name="model">fleet.branch</field>
        <field name="arch" type="xml">
            <list string="Fleet Branches">
                <field name="name"/>
            </list>
        </field>
    </record>

    <!-- Form View for Fleet Branch -->
    <record id="view_fleet_branch_form" model="ir.ui.view">
        <field name="name">fleet.branch.form</field>
        <field name="model">fleet.branch</field>
        <field name="arch" type="xml">
            <form string="Fleet Branch">
                <sheet>
                    <group>
                        <field name="name" placeholder="Enter branch name..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View for Fleet Branch -->
    <record id="view_fleet_branch_search" model="ir.ui.view">
        <field name="name">fleet.branch.search</field>
        <field name="model">fleet.branch</field>
        <field name="arch" type="xml">
            <search string="Fleet Branches">
                <field name="name" string="Name" filter_domain="['|', ('name', 'ilike', self), ('name', 'ilike', self)]"/>
            </search>
        </field>
    </record>

    <!-- Action for Fleet Branch -->
    <record id="action_fleet_branch" model="ir.actions.act_window">
        <field name="name">ფილიალები</field>
        <field name="res_model">fleet.branch</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first fleet branch!
            </p>
            <p>
                Manage your fleet branches here.
            </p>
        </field>
    </record>
</odoo>

